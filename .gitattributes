# Normalizacion de finales de linea para el repositorio Prosperas
# Los scripts shell DEBEN conservar LF (Unix) para ejecutarse correctamente en Linux/Docker
* text=auto
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.env text eol=lf

# Archivos binarios - sin conversion de finales de linea
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.zip binary
*.gz binary
*.tar binary
