# Imagen versionada en ECR
BACKEND_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/prosperas-backend:latest
FRONTEND_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/prosperas-backend:frontend-latest

# App
APP_ENV=production
APP_PORT=8000
JWT_SECRET_KEY=cambia-esto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# AWS
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=

# DynamoDB
DYNAMODB_TABLE_NAME=prosperas-jobs
DYNAMODB_USER_INDEX_NAME=user_id-index

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/prosperas-jobs-queue
SQS_PRIORITY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/prosperas-jobs-priority-queue
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/prosperas-jobs-dlq
SQS_PRIORITY_REPORT_KEYWORDS=priority,urgent,critico,critica

# Worker retries
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_SECONDS=2
WORKER_RETRY_MAX_SECONDS=60
WORKER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=2
WORKER_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
REALTIME_STREAM_INTERVAL_SECONDS=2

# Frontend/CORS
CORS_ALLOWED_ORIGINS=http://EC2_PUBLIC_IP,http://EC2_PUBLIC_IP:5173,https://tu-dominio.com

# Usuario demo (solo para demo tecnica)
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123
