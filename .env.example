# Entorno general
APP_ENV=local
APP_PORT=8000

# Seguridad
JWT_SECRET_KEY=cambia-esto-en-local
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# AWS y LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# DynamoDB
DYNAMODB_TABLE_NAME=prosperas-jobs
DYNAMODB_USER_INDEX_NAME=user_id-index

# SQS
SQS_QUEUE_URL=http://localstack:4566/000000000000/prosperas-jobs-queue
SQS_PRIORITY_QUEUE_URL=http://localstack:4566/000000000000/prosperas-jobs-priority-queue
SQS_DLQ_URL=http://localstack:4566/000000000000/prosperas-jobs-dlq
SQS_PRIORITY_REPORT_KEYWORDS=priority,urgent,critico,critica

# Worker retries y backoff
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_SECONDS=2
WORKER_RETRY_MAX_SECONDS=60

# Frontend local y CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=http://localhost:8000

# Usuario demo para login base en Fase 1
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123
